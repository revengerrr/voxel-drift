# commit: chore: add env example for Supabase config
# description: Template for environment variables. Copy to .env.local
# and fill in your Supabase project credentials. The game runs in
# offline mode (no leaderboard) if these are not set.

# Supabase — get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
